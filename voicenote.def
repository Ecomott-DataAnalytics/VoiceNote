Bootstrap: docker
# CUDA 12系へ更新（Qwen3-ASR / 最新transformers / 新しいfaster-whisperに必要）。
# ホストのNVIDIAドライバが対応するCUDAに合わせてタグを選ぶこと:
#   12.4.1 -> ドライバ R550+ / 12.1.1 -> R530+
From: nvcr.io/nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

%setup
    echo "Asia/Tokyo" > ${SINGULARITY_ROOTFS}/etc/timezone
    mkdir -p ${SINGULARITY_ROOTFS}/app/templates
    mkdir -p ${SINGULARITY_ROOTFS}/app/static/css
    mkdir -p ${SINGULARITY_ROOTFS}/app/static/js
    mkdir -p ${SINGULARITY_ROOTFS}/app/engines
    mkdir -p ${SINGULARITY_ROOTFS}/app/config

%post
    export DEBIAN_FRONTEND=noninteractive
    export TZ=Asia/Tokyo

    apt-get update && apt-get upgrade -y
    # Ubuntu 22.04 は python3.10 を標準搭載
    apt-get install -y python3 python3-dev python3-venv python3-pip \
        git curl wget ca-certificates redis-server ffmpeg

    python3 -m pip install --upgrade pip

    # --- 機械学習ランタイム ---------------------------------------------------
    # PyTorch (CUDA 12.4)。V100(sm_70)〜RTX4090(sm_89)を1イメージで対応する。
    # 重要: CUDA 13系(cu130)はVolta(V100)サポートを削除しているため使わない。
    pip3 install torch torchaudio --index-url https://download.pytorch.org/whl/cu124

    # 以降の pip が torch/torchaudio を PyPI版(cu130等)へ上書きしないよう固定する。
    # pyannote.audio / qwen-asr / torchaudio などが torch を引き直すのを防ぐ。
    python3 - <<'PY'
import torch, torchaudio
with open("/opt/torch-constraints.txt", "w") as f:
    f.write("torch==%s\n" % torch.__version__)
    f.write("torchaudio==%s\n" % torchaudio.__version__)
PY
    export PIP_CONSTRAINT=/opt/torch-constraints.txt

    # Faster-Whisper（ctranslate2 を同梱。CUDA 12 / cuDNN 9 対応）
    pip3 install faster-whisper

    # transformers 系（Kotoba / 一般ASRパイプライン）。torchaudioは再指定しない。
    pip3 install transformers accelerate

    # Kotoba v2.2（話者分離）依存
    pip3 install "punctuators==0.0.5" "pyannote.audio"
    pip3 install git+https://github.com/huggingface/diarizers.git

    # ReazonSpeech k2-v2（公式SDK + sherpa-onnx）
    git clone https://github.com/reazon-research/ReazonSpeech /opt/ReazonSpeech
    pip3 install /opt/ReazonSpeech/pkg/k2-asr
    pip3 install sherpa-onnx

    # Qwen3-ASR（独自パッケージ。既定は transformers バックエンド）
    pip3 install qwen-asr
    # vLLMバックエンドを使う場合のみ有効化（V100ではxformers backendで最適化は限定的）:
    # pip3 install "qwen-asr[vllm]"

    # --- Web / タスクキュー / ユーティリティ ----------------------------------
    pip3 install flask gunicorn celery redis psutil gputil flask-cors pyyaml

    # torch が CUDA 12 系のままか検証（cu130 等に化けていたらビルドを失敗させる）
    python3 -c "import torch; v=torch.__version__; print('torch', v); assert '+cu12' in v, 'torch must be a CUDA 12.x build for V100(sm_70) support, got: '+v"

%files
    # ディレクトリ一括コピーは %setup の mkdir 先と噛み合って配置がずれるため、
    # 動作実績のある templates/static と同様に「ファイル→フルパス」で個別コピーする。
    voicenote.py /app/voicenote.py
    requirements.txt /app/requirements.txt
    engines/__init__.py /app/engines/__init__.py
    engines/base.py /app/engines/base.py
    engines/factory.py /app/engines/factory.py
    engines/chunking.py /app/engines/chunking.py
    engines/faster_whisper_engine.py /app/engines/faster_whisper_engine.py
    engines/kotoba_engine.py /app/engines/kotoba_engine.py
    engines/qwen3_asr_engine.py /app/engines/qwen3_asr_engine.py
    engines/reazon_engine.py /app/engines/reazon_engine.py
    config/__init__.py /app/config/__init__.py
    config/models.yaml /app/config/models.yaml
    templates/index.html /app/templates/index.html
    static/css/style.css /app/static/css/style.css
    static/js/main.js /app/static/js/main.js

%test
    # パッケージ配置とYAML読込のスモークテスト（重いMLモデルはロードしない）。
    # voicenote.py が遅延importする engines.chunking もここで読み込み、
    # %files への入れ忘れがビルド時に落ちるようにする。
    cd /app
    python3 -c "import config; from engines.factory import EngineFactory; from engines.chunking import to_wav, transcribe_chunked; print('package layout OK:', EngineFactory)"
    python3 -c "import config; print('models loaded:', len(config.list_models()))"

%environment
    CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-0}
    # Qwen3-ASR のバックエンド (transformers | vllm)
    QWEN_ASR_BACKEND=${QWEN_ASR_BACKEND:-transformers}
    # Kotoba v2.2 の話者分離には HuggingFace トークンが必要。
    # 起動時に SINGULARITYENV_HF_TOKEN=xxxx を渡すと HF_TOKEN として参照される。
    export HF_TOKEN=${HF_TOKEN:-}

%runscript
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-0}
    redis-server --daemonize yes
    cd /app
    pkill -f 'celery worker'

    # 既定: GPU 1枚で Celery ワーカー1本。
    celery -A voicenote.celery worker --loglevel=INFO -n worker1@%h -P solo &

    # --- マルチGPU(V100 x4)で最大4件同時処理したい場合の例 ---------------------
    # 上の1本起動をコメントアウトし、以下のように各ワーカーをGPUに固定する:
    # CUDA_VISIBLE_DEVICES=0 celery -A voicenote.celery worker --loglevel=INFO -n worker0@%h -P solo &
    # CUDA_VISIBLE_DEVICES=1 celery -A voicenote.celery worker --loglevel=INFO -n worker1@%h -P solo &
    # CUDA_VISIBLE_DEVICES=2 celery -A voicenote.celery worker --loglevel=INFO -n worker2@%h -P solo &
    # CUDA_VISIBLE_DEVICES=3 celery -A voicenote.celery worker --loglevel=INFO -n worker3@%h -P solo &

    pkill gunicorn
    gunicorn --bind 0.0.0.0:5000 -k sync -w 4 --timeout 7500 --graceful-timeout 300 --keep-alive 5 --max-requests 1000 --max-requests-jitter 50 voicenote:app
